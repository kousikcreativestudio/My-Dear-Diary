rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function ownsDocument() {
      return request.auth != null && resource.data.uid == request.auth.uid;
    }

    function createsOwnDocument() {
      return request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    match /diaryEntries/{entryId} {
      allow create: if createsOwnDocument();
      allow read, delete: if ownsDocument();
      allow update: if ownsDocument() && createsOwnDocument();
    }

    match /vaultEntries/{entryId} {
      allow create: if createsOwnDocument();
      allow read, delete: if ownsDocument();
      allow update: if ownsDocument() && createsOwnDocument();
    }

    match /timeCapsules/{capsuleId} {
      allow create: if createsOwnDocument();
      allow read, delete: if ownsDocument();
      allow update: if ownsDocument() && createsOwnDocument();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
